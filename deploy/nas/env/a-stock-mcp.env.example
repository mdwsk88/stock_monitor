# 群晖 DS218+（6G）推荐参数
SPRING_PROFILES_ACTIVE=prod
TZ=Asia/Shanghai
JAVA_OPTS=-Xms128m -Xmx512m -Duser.timezone=Asia/Shanghai -XX:+ExitOnOutOfMemoryError
A_STOCK_MCP_LANGUAGE=zh

# a-stock-mcp 读取和 stock-web 同一套业务库即可
# 采用 host network 后，容器可直接访问 NAS 本机的 127.0.0.1:3306
# serverTimezone 建议与 NAS 上数据库实例的真实时区保持一致；不确定时先沿用当前项目默认的 UTC
A_STOCK_MCP_DB_URL=jdbc:mysql://127.0.0.1:3306/stock_monitor?useUnicode=true&characterEncoding=UTF-8&autoReconnect=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
A_STOCK_MCP_DB_USERNAME=root
A_STOCK_MCP_DB_PASSWORD=replace_me

# 当前版本工具链不依赖 SMTP；后续如果恢复邮件相关工具，再补真实值
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
