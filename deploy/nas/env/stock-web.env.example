# 自托管 NAS / 家庭服务器推荐参数
SPRING_PROFILES_ACTIVE=prod
TZ=Asia/Shanghai
JAVA_OPTS=-Xms256m -Xmx768m -Duser.timezone=Asia/Shanghai -XX:+ExitOnOutOfMemoryError

# DeepSeek / OpenAI 兼容接口
# 项目内优先使用 STOCK_OPENAI_*，避免和其他工具共用 OPENAI_* 变量时互相干扰
STOCK_OPENAI_API_KEY=replace_me
STOCK_OPENAI_BASE_URL=https://api.deepseek.com
STOCK_OPENAI_CHAT_MODEL=deepseek-chat

BAIDU_TRANSLATE_HOST=https://fanyi-api.baidu.com/api/trans/vip/translate
BAIDU_TRANSLATE_APPID=replace_me
BAIDU_TRANSLATE_SECURITYKEY=replace_me

DINGDING_TOKEN=
DINGDING_SECRET=
DINGDING_USERID=

WECOM_WEBHOOK_URL_US=
WECOM_WEBHOOK_URL_A=
WECOM_WEBHOOK_URL_HK=
WECOM_WEBHOOK_URL=

# 采用 host network 后，容器可直接访问 NAS 本机的 127.0.0.1:3306
# serverTimezone 建议与 NAS 上数据库实例的真实时区保持一致；不确定时先沿用当前项目默认的 UTC
STOCK_WEB_DB_URL=jdbc:mysql://127.0.0.1:3306/stock_monitor?useUnicode=true&characterEncoding=UTF-8&autoReconnect=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
STOCK_WEB_DB_USERNAME=stock_monitor
STOCK_WEB_DB_PASSWORD=replace_me
