# ============================================
# 环境变量配置模板
# ============================================
# 1. 复制此文件为 .env
# 2. 填入真实的配置值
# 3. 永远不要将 .env 提交到 Git！
# ============================================

# 百度翻译 API（可选，如果不使用翻译功能可留空）
BAIDU_TRANSLATE_HOST=https://fanyi-api.baidu.com/api/trans/vip/translate
BAIDU_TRANSLATE_APPID=your_baidu_appid
BAIDU_TRANSLATE_SECURITYKEY=your_baidu_secret

# 钉钉机器人（可选）
DINGDING_TOKEN=your_dingtalk_token
DINGDING_SECRET=your_dingtalk_secret
DINGDING_USERID=

# 企业微信 Webhook（必填）
WECOM_WEBHOOK_URL_US=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your_us_stock_key
WECOM_WEBHOOK_URL_A=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your_a_stock_key
WECOM_WEBHOOK_URL_HK=
WECOM_WEBHOOK_URL=

# Spring AI / OpenAI 配置（必填）
# 如果使用 OpenAI 官方 API，请配置 OPENAI_API_KEY
# 如果使用国内代理（如硅基流动、DeepSeek等），需要同时配置 OPENAI_BASE_URL 和 OPENAI_API_KEY
# 示例（硅基流动）: OPENAI_BASE_URL=https://api.siliconflow.cn/v1
# 示例（DeepSeek）: OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_API_KEY=your_api_key_here
OPENAI_CHAT_MODEL=deepseek-chat
