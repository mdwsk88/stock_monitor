# 复制本文件为项目根目录 .env，并填入真实值。
# 不要把真实 .env 提交到 Git。

# 运行 profile，可选 dev / prod
SPRING_PROFILES_ACTIVE=prod

# =========================
# stock-web
# =========================
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_CHAT_MODEL=deepseek-chat

BAIDU_TRANSLATE_HOST=https://fanyi-api.baidu.com/api/trans/vip/translate
BAIDU_TRANSLATE_APPID=your_baidu_appid
BAIDU_TRANSLATE_SECURITYKEY=your_baidu_secret

DINGDING_TOKEN=your_dingtalk_token
DINGDING_SECRET=your_dingtalk_secret
DINGDING_USERID=

WECOM_WEBHOOK_URL_US=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your_us_stock_key
WECOM_WEBHOOK_URL_A=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your_a_stock_key
WECOM_WEBHOOK_URL_HK=
WECOM_WEBHOOK_URL=

STOCK_WEB_DB_URL=jdbc:mysql://127.0.0.1:3307/stock_monitor_prod?useUnicode=true&characterEncoding=UTF-8&autoReconnect=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
STOCK_WEB_DB_USERNAME=root
STOCK_WEB_DB_PASSWORD=change_me

# =========================
# us-stock-mcp
# =========================
US_STOCK_MCP_DB_URL=jdbc:mysql://127.0.0.1:3307/stock_monitor_prod?useUnicode=true&characterEncoding=UTF-8&autoReconnect=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
US_STOCK_MCP_DB_USERNAME=root
US_STOCK_MCP_DB_PASSWORD=change_me

# =========================
# a-stock-mcp
# =========================
A_STOCK_MCP_DB_URL=jdbc:mysql://127.0.0.1:3307/stock_monitor_prod?useUnicode=true&characterEncoding=UTF-8&autoReconnect=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
A_STOCK_MCP_DB_USERNAME=root
A_STOCK_MCP_DB_PASSWORD=change_me

# =========================
# shared SMTP
# =========================
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USERNAME=your_mail_username
SMTP_PASSWORD=your_mail_password
