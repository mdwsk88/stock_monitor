<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dawei.mapper.AStockRssMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.dawei.entity.AStockRss">
        <id column="id" property="id" />
        <result column="stock_code" property="stockCode" />
        <result column="stock_name" property="stockName" />
        <result column="title" property="title" />
        <result column="link" property="link" />
        <result column="pub_date" property="pubDate" />
        <result column="tag" property="tag" />
    </resultMap>

    <!-- 查询指定日期段内股票出现次数统计 -->
    <select id="queryStockCountsBetweenDate" parameterType="map" resultType="com.dawei.entity.StockCounts">
        SELECT
            stock_code AS stockCode,
            stock_name AS stockName,
            COUNT(*) AS occurCounts
        FROM
            a_stock_rss
        WHERE
            pub_date &lt;= #{paramMap.endDate} AND pub_date &gt;= #{paramMap.startDate}
        GROUP BY
            stock_code, stock_name
        HAVING
            occurCounts &gt;= #{paramMap.targetCounts}
        ORDER BY
            occurCounts DESC
    </select>

    <!-- 根据标题关键字查询股票数据 -->
    <select id="queryStockByTitleKeywords" resultType="com.dawei.entity.AStockRss">
        SELECT
            *
        FROM
            a_stock_rss
        WHERE
            (
                <foreach collection="keywords" item="kw" separator=" OR ">
                    title LIKE CONCAT('%', #{kw}, '%')
                </foreach>
            )
        ORDER BY
            pub_date DESC
    </select>

    <!-- 根据股票名称关键字查询 -->
    <select id="queryStockByNameKeywords" resultType="com.dawei.entity.AStockRss">
        SELECT
            *
        FROM
            a_stock_rss
        WHERE
            (
                <foreach collection="keywords" item="kw" separator=" OR ">
                    stock_name LIKE CONCAT('%', #{kw}, '%')
                </foreach>
            )
        ORDER BY
            pub_date DESC
    </select>

</mapper>
